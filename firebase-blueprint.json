{
  "entities": {
    "Member": {
      "title": "Gym Member",
      "description": "Details of a Spartan Gym member",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the member" },
        "phone": { "type": "string", "description": "Contact number" },
        "membershipCode": { "type": "string", "description": "Unique code used for login" },
        "plan": { "type": "string", "description": "Selected membership plan (e.g., 1 Month)" },
        "status": { 
          "type": "string", 
          "enum": ["active", "paused", "expired", "extended"],
          "description": "Current status of the membership"
        },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Initial expiry date" },
        "extendedDate": { "type": "string", "format": "date-time", "description": "Extended date if applicable" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "membershipCode", "plan", "status"]
    },
    "Admin": {
      "title": "Gym Admin",
      "description": "Administrative user for the gym",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["super-admin", "trainer"] }
      },
      "required": ["uid", "email"]
    },
    "Staff": {
      "title": "Gym Staff",
      "description": "Staff member with access code",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "staffCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "staffCode"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of all gym members"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized administrators"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Collection of gym staff members"
    }
  }
}
